{
  "name": "novel-writing-agent-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/generate-sitemap.mjs && tsc && vite build",
    "postbuild": "node scripts/generate-sitemap.mjs && node scripts/prerender-marketing.mjs",
    "sitemap": "node scripts/generate-sitemap.mjs",
    "seo:verify": "node scripts/verify-seo-crawl.mjs",
    "seo:ping": "node scripts/ping-search-engines.mjs",
    "build:skip-prerender": "cross-env SKIP_PRERENDER=1 tsc && vite build",
    "prerender": "node scripts/prerender-marketing.mjs",
    "build:analyze": "cross-env ANALYZE=true tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 50",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/geist": "^5.2.9",
    "@react-spring/three": "9.6.1",
    "@react-three/fiber": "8.13.5",
    "@streamdown/cjk": "1.0.3",
    "@streamdown/code": "^1.0.3",
    "@tabler/icons-react": "^3.44.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-virtual": "^3.10.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "gsap": "^3.15.0",
    "i18next": "^23.10.0",
    "lucide-react": "^1.17.0",
    "radix-ui": "^1.4.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^14.0.5",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.22.0",
    "reagraph": "4.22.0",
    "recharts": "^2.15.3",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.10.0",
    "streamdown": "2.5.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "three": "^0.154.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^4.5.0"
  },
  "pnpm": {
    "overrides": {
      "react": "$react",
      "react-dom": "$react-dom"
    }
  },
  "devDependencies": {
    "@iconify-json/solar": "^1.2.5",
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^25.9.1",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-basic-ssl": "^1.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "cross-env": "^7.0.3",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "javascript-obfuscator": "^4.1.1",
    "jsdom": "^26.0.0",
    "rollup-plugin-visualizer": "^5.14.0",
    "terser": "^5.39.0",
    "typescript": "^5.3.3",
    "vite": "^5.1.0",
    "vitest": "^2.1.9"
  },
  "packageManager": "pnpm@9.15.4+sha512.b2dc20e2fc72b3e18848459b37359a32064663e5627a51e4c74b2c29dd8e8e0491483c3abb40789cfd578bf362fb6ba8261b05f0387d76792ed6e23ea3b1b6a0"
}
