# 生产构建默认开启 AES（可被 VITE_SECURITY_AES 覆盖）
VITE_SECURITY_AES=true
# Phase 0e：生产构建默认 true（vite.config.ts define）；本地 dev 可设 false
VITE_ROUTE_OBFUSCATION=true
VITE_FIELD_ENCRYPTION=true
# Agent SSE stream body AES（与 gateway encrypt-stream 对齐）
VITE_SECURITY_ENCRYPT_STREAM=true
# Cloudflare Turnstile（本地开发：site key 可放 frontend/.env.local；secret 放 scripts/local-cn.env）
# 生产：Worker 注入 TURNSTILE_*，前端运行时 GET /api/auth/api/captcha/config 获取 site key
# VITE_TURNSTILE_SITE_KEY=
# 生产构建默认开启 JS 混淆（Terser + javascript-obfuscator）；调试可设 false
VITE_CODE_OBFUSCATION=true
# 编辑器 @ 参考书引用（dev 默认 true；prod 灰度可设 false）
VITE_FEATURE_LIBRARY_REF=true
