# =============================================================================
# LLM Provider Configuration (MiniMax recommended: Anthropic protocol)
# =============================================================================

ACTIVE_PROVIDER=openai
LLM_PROTOCOL=anthropic

# MiniMax Anthropic-compatible endpoint (M2.7 / Agent models)
OPENAI_API_KEY=your-minimax-api-key
OPENAI_BASE_URL=https://api.minimaxi.com/anthropic
OPENAI_MODEL=MiniMax-M2.7-highspeed
OPENAI_MAX_TOKENS=8192
OPENAI_TIMEOUT=90
OPENAI_PLAN_MAX_TOKENS=8192
OPENAI_PLAN_TIMEOUT=120
OPENAI_TEMPERATURE=1.0

# Legacy OpenAI-compatible endpoint (set LLM_PROTOCOL=openai to use)
# OPENAI_BASE_URL=https://api.minimaxi.com/v1

# DeepSeek provider config
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# =============================================================================
# Vector Database (Milvus)
# =============================================================================
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=

# =============================================================================
# Service Configuration
# =============================================================================
# Docker Worker 栈内 Content 服务名（勿用 127.0.0.1）
CONTENT_BASE_URL=http://agent-content:8091
INTERNAL_SERVICE_KEY=prod-internal-key-novel-agent
LOG_LEVEL=INFO
AGENT_LLM_TRACE=true

# =============================================================================
# Agnes Image Generation (滑块验证码 / 书籍封面)
# =============================================================================
AGNES_IMAGE_API_KEY=
AGNES_IMAGE_BASE_URL=https://apihub.agnes-ai.com
AGNES_IMAGE_MODEL=agnes-image-2.0-flash
AGNES_IMAGE_TIMEOUT=120

# Crawler
CRAWL_REQUEST_DELAY_MS=800

# 爬虫出口代理（绕过 WAF / 机房 IP 封禁）
# 格式：http://用户名:密码@代理主机:端口  或  socks5://...
# 来源（需自行购买，无内置免费代理）：
#   - 住宅/动态代理：Bright Data、Oxylabs、Smartproxy、IPIDEA、快代理、芝麻代理等
#   - 在服务商控制台创建「HTTP 代理」，复制连接串到此处
#   - 自建：V2Ray/Squid 等有干净出口 IP 的节点
# 多代理轮询（可选，逗号分隔；设置后每次请求轮换）
CRAWL_HTTP_PROXY=
CRAWL_PROXY_LIST=
