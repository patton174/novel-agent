# =============================================================================
# LLM Provider Configuration (MiniMax recommended: Anthropic protocol)
# =============================================================================

ACTIVE_PROVIDER=openai
LLM_PROTOCOL=anthropic

# MiniMax Anthropic-compatible endpoint (M2.7 / Agent models)
OPENAI_API_KEY=your-minimax-api-key
OPENAI_BASE_URL=https://api.minimaxi.com/anthropic
OPENAI_MODEL=MiniMax-M2.7-highspeed
OPENAI_MAX_TOKENS=8192
OPENAI_TIMEOUT=90
OPENAI_PLAN_MAX_TOKENS=8192
OPENAI_PLAN_TIMEOUT=120
OPENAI_TEMPERATURE=1.0

# Legacy OpenAI-compatible endpoint (set LLM_PROTOCOL=openai to use)
# OPENAI_BASE_URL=https://api.minimaxi.com/v1

# DeepSeek provider config
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# =============================================================================
# Vector Database (Milvus)
# =============================================================================
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=

# =============================================================================
# Service Configuration
# =============================================================================
# Docker Worker 栈内 Content 服务名（勿用 127.0.0.1）
CONTENT_BASE_URL=http://agent-content:8091
INTERNAL_SERVICE_KEY=prod-internal-key-novel-agent
LOG_LEVEL=INFO
AGENT_LLM_TRACE=true

# =============================================================================
# Agnes Image Generation (滑块验证码 / 书籍封面)
# =============================================================================
AGNES_IMAGE_API_KEY=
AGNES_IMAGE_BASE_URL=https://apihub.agnes-ai.com
AGNES_IMAGE_MODEL=agnes-image-2.0-flash
AGNES_IMAGE_TIMEOUT=120

# Crawl subtask LLM (Agnes-2.0-Flash, OpenAI-compatible Chat Completions)
# 未填 CRAWL_LLM_API_KEY 时回退使用 AGNES_IMAGE_API_KEY
CRAWL_LLM_API_KEY=
CRAWL_LLM_BASE_URL=https://apihub.agnes-ai.com/v1
CRAWL_LLM_MODEL=agnes-2.0-flash
CRAWL_LLM_MAX_TOKENS=8192
CRAWL_LLM_TIMEOUT=120
CRAWL_LLM_TEMPERATURE=0.7

# Crawler
CRAWL_REQUEST_DELAY_MS=800

# Scrapling HTTP：Linux 上建议 chrome124，避免 curl_cffi 最新 chrome 指纹 TLS 异常
CRAWL_IMPERSONATE=chrome124
CRAWL_FETCH_CONCURRENCY=3
CRAWL_HTTP_RETRIES=2
CRAWL_HTTP_TIMEOUT=45
# 代理 TLS 失败时尝试 Stealth 浏览器（需容器内存 ≥512MB，见 PYTHON_MEM_LIMIT）
CRAWL_BROWSER_FETCH_ENABLED=true
CRAWL_BROWSER_CONCURRENCY=1
CRAWL_BROWSER_TIMEOUT_MS=60000
# 代理无法连通目标站 TLS 时，最后尝试 Worker 直连（可能 403，但优于完全失败）
CRAWL_TLS_RETRY_DIRECT=true

# 爬虫出口代理（绕过 WAF / 机房 IP 封禁）
# 格式：http://用户名:密码@代理主机:端口  或  socks5://...
# 来源（需自行购买，无内置免费代理）：
#   - 住宅/动态代理：Bright Data、Oxylabs、Smartproxy、IPIDEA、快代理、芝麻代理等
#   - 在服务商控制台创建「HTTP 代理」，复制连接串到此处
#   - 自建：V2Ray/Squid 等有干净出口 IP 的节点
# 多代理轮询（可选，逗号分隔；设置后每次请求轮换）
CRAWL_HTTP_PROXY=
CRAWL_PROXY_LIST=
# mihomo 自动换节点（Worker：HTTP 代理 + 外部控制器 API）
# Docker 容器访问宿主机 mihomo：API 用 172.24.0.1:9090，代理用 172.24.0.1:7890
# 需将 mihomo external-controller 改为 0.0.0.0:9090（见 patch-mihomo-config.py）
CRAWL_MIHOMO_API=
CRAWL_MIHOMO_SECRET=
CRAWL_MIHOMO_PROXY_GROUP=🚀 节点选择
CRAWL_MIHOMO_MAX_NODES=12
CRAWL_MIHOMO_FAIL_COOLDOWN_SEC=300
# Worker 上启用全局爬虫主编排 Agent（生产环境建议 true）
CRAWL_ORCHESTRATOR_ENABLED=true
CRAWL_ORCHESTRATOR_POLL_SEC=30
