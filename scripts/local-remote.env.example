# 本地开发连线上 MW 中间件（复制为 local-remote.env 后填写，勿提交）
# 也可直接复用 novel-agent/agent-document/docs/deploy/docker/.env.mw（脚本会自动读取）

MW_HOST=107.150.112.140

DB_HOST=107.150.112.140
DB_PORT=5432
DB_NAME=novel_agent
DB_USER=postgres
DB_PASSWORD=

REDIS_HOST=107.150.112.140
REDIS_PORT=6379
REDIS_PASSWORD=

RABBITMQ_HOST=107.150.112.140
RABBITMQ_PORT=5672
RABBITMQ_USER=novel_agent
RABBITMQ_PASSWORD=

# RAG 向量库（部署在 MW，见 novel-studio/deploy/ci/deploy-milvus.sh）
MILVUS_HOST=107.150.112.140
MILVUS_PORT=19530

# 与线上 Worker novel-studio 一致（python-ai 调 /api/content/auth/*）
AGENT_INTERNAL_SERVICE_KEY=

# Agent 运行时（默认与 production 对齐：queued + PG run + MQ dispatch）
# AGENT_RUNTIME_MODE=queued
# AGENT_PG_RUN_ENABLED=true
# AGENT_MQ_LISTENER_AUTO_STARTUP=true
# 仅调试 Java 直连 Python 时可临时改 legacy（会丢失 SSE 重连 / run 持久化等行为）：
# AGENT_RUNTIME_MODE=legacy
# AGENT_PG_RUN_ENABLED=false
# AGENT_MQ_LISTENER_AUTO_STARTUP=false
