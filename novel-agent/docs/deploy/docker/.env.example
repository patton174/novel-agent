# 远程 Docker 部署环境变量（复制为 .env 后修改）
# cp .env.example .env

DEPLOY_REMOTE=root@YOUR_MW_HOST
DEPLOY_REMOTE_DIR=/opt/novel-agent

HOST_IP=YOUR_MW_HOST
MW_HOST=YOUR_MW_HOST
WORKER_HOST=YOUR_WORKER_HOST

NACOS_SERVER_ADDR=YOUR_MW_HOST:8848
NACOS_USERNAME=nacos
NACOS_PASSWORD=changeme
NACOS_NAMESPACE=YOUR_NACOS_NAMESPACE_UUID
NACOS_AUTH_IDENTITY_KEY=root
NACOS_AUTH_IDENTITY_VALUE=changeme

FRONTEND_PORT=3000
GATEWAY_PORT=8080
PYTHON_LB_PORT=8000

SPRING_PROFILES_ACTIVE=dev

# JWT 签名密钥（≥32 字符；MW auth/gateway 必须一致）
JWT_SECRET=change-me-to-at-least-32-characters-long

# Worker 向 Auth 注册 bootstrap 密钥（internal API）
AGENT_INTERNAL_SERVICE_KEY=change-me-internal-service-key
