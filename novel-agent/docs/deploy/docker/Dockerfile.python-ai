# Scrapling StealthyFetcher 依赖 Patchright Chromium（见 https://github.com/d4vinci/Scrapling ）
FROM python:3.12-slim-bookworm

WORKDIR /app
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PLAYWRIGHT_BROWSERS_PATH=/root/.cache/ms-playwright

COPY python-ai/requirements.txt /app/requirements.txt

# patchright install-deps 会安装 Chromium 所需的系统库
RUN pip install --no-cache-dir -r requirements.txt \
    && patchright install-deps chromium \
    && patchright install chromium \
    && rm -rf /root/.cache/pip

COPY python-ai/app /app/app
EXPOSE 8000
CMD ["python", "-m", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
