@echo off
REM Copy to env.bat and edit paths for your server.
REM   copy env.bat.example env.bat

REM JDK 17+ required
set JAVA_HOME=D:\Programs\Java\jdk_21
set PATH=%JAVA_HOME%\bin;%PATH%

REM Spring profile
REM   local = localhost + routes in application-local.yml (dev scripts default)
REM   dev   = Nacos + server middleware (192.168.6.24)
set SPRING_PROFILES_ACTIVE=local

REM Nacos (only when SPRING_PROFILES_ACTIVE=dev)
set NACOS_SERVER_ADDR=10.8.0.107:8848
set NACOS_USERNAME=nacos
set "NACOS_PASSWORD=changeme"
set NACOS_NAMESPACE=dev

REM JVM
set JAVA_OPTS=-Xms256m -Xmx768m -Dfile.encoding=UTF-8

REM Repo root — 改成你的 clone 路径（默认 novel-ai-platform）
set PROJECT_ROOT=D:\Users\JZJ\Desktop\novel-ai-platform
set PYTHON_EXE=python

REM Server LAN IP is 192.168.6.24 (Ethernet0). Gateway :8080 is fine for NETWORK;
REM 503 was Spring Cloud "no instance for lb://agent-auth", not wrong IP.
REM
REM Dev on another PC (e.g. 192.168.43.x):
set "VITE_REMOTE_AUTH=http://192.168.6.24:8081"
REM Dev on the server itself (same machine as Auth):
REM set "VITE_REMOTE_AUTH=http://127.0.0.1:8081"
set "VITE_LOCAL_PYAI=http://127.0.0.1:8082"
