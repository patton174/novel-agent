# MW → Worker 单 python-ai 实例（LLM）；爬虫在 Worker nginx 内分流至国内节点
upstream python_ai_worker {
    server ${WORKER_HOST}:8000 max_fails=3 fail_timeout=30s;
}

server {
    listen 8000;
    server_name _;

    location / {
        proxy_pass http://python_ai_worker;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    location /health {
        proxy_pass http://python_ai_worker/api/health;
    }
}
