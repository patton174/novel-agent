<mj-section background-color="__brandSurface__" padding="20px 24px 16px" border="2px solid __brandBorder__">
  <mj-column width="100%">
    <mj-text
      align="left"
      font-family="'Courier New', Courier, 'Lucida Console', monospace"
      font-size="18px"
      font-weight="700"
      color="__brandText__"
      padding="0"
      letter-spacing="0.04em"
    >
      __productName__
    </mj-text>
    <mj-text
      align="left"
      font-family="'Courier New', Courier, 'Lucida Console', monospace"
      font-size="12px"
      color="__brandMuted__"
      padding="6px 0 0"
      letter-spacing="0.02em"
    >
      __tagline__
    </mj-text>
  </mj-column>
</mj-section>
