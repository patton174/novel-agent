<mj-section background-color="__brandSurface__" padding="24px 32px 16px" border-radius="16px 16px 0 0">
  <mj-column width="100%">
    <mj-text align="center" padding="0 0 8px">
      <span style="display:inline-block;width:40px;height:40px;line-height:40px;border-radius:12px;background:linear-gradient(135deg,__brandPrimary__,__brandGradientEnd__);color:#ffffff;font-weight:700;font-size:18px;">N</span>
    </mj-text>
    <mj-text align="center" font-size="20px" font-weight="700" color="__brandText__" padding="0">
      __productName__
    </mj-text>
    <mj-text align="center" font-size="13px" color="__brandMuted__" padding="4px 0 0">
      __tagline__
    </mj-text>
  </mj-column>
</mj-section>
