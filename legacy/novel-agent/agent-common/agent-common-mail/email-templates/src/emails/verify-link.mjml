<mjml lang="zh-CN">
  <mj-head>
    <mj-title>__productName__ 邮箱验证</mj-title>
    <mj-preview>请点击按钮完成邮箱验证，链接 __ttlLabel__ 内有效。</mj-preview>
    <mj-attributes>
      <mj-all font-family="'Segoe UI', 'PingFang SC', 'Microsoft YaHei', Helvetica, Arial, sans-serif" />
      <mj-text color="__brandText__" font-size="16px" line-height="26px" />
      <mj-button
        background-color="__brandPrimary__"
        color="#ffffff"
        font-size="16px"
        font-weight="600"
        border-radius="999px"
        inner-padding="14px 32px"
      />
    </mj-attributes>
    <mj-style inline="inline">
      .link-fallback { word-break: break-all; color: __brandPrimary__ !important; }
      @media only screen and (max-width: 480px) {
        .mobile-pad { padding-left: 16px !important; padding-right: 16px !important; }
      }
    </mj-style>
  </mj-head>
  <mj-body background-color="__brandBackground__" width="600px">
    <mj-wrapper padding="24px 12px" css-class="mobile-pad">
      <mj-section padding="0">
        <mj-column>
          <mj-spacer height="8px" />
        </mj-column>
      </mj-section>

      <mj-include path="../partials/header.mjml" />

      <mj-section background-color="__brandSurface__" padding="8px 32px 0">
        <mj-column>
          <mj-text font-size="22px" font-weight="700" color="__brandText__" padding="0 0 8px">
            验证您的邮箱
          </mj-text>
          <mj-text color="__brandMuted__" padding="0 0 16px">
            您正在 __productName__ 账户中验证邮箱。点击下方按钮即可完成验证；若按钮无法打开，请复制下方链接到浏览器。
          </mj-text>
        </mj-column>
      </mj-section>

      <mj-section background-color="__brandSurface__" padding="8px 32px 24px">
        <mj-column>
          <mj-button href="__verifyUrl__" align="center">
            验证邮箱
          </mj-button>
          <mj-text font-size="13px" color="__brandMuted__" padding="20px 0 0" align="center">
            链接 __ttlLabel__ 内有效
          </mj-text>
        </mj-column>
      </mj-section>

      <mj-section background-color="__brandSurface__" padding="0 32px 24px">
        <mj-column background-color="#f8fafc" border-radius="12px" border="1px solid __brandBorder__">
          <mj-text font-size="12px" color="__brandMuted__" padding="16px" css-class="link-fallback">
            备用链接：<br />
            <a href="__verifyUrl__" style="color:__brandPrimary__;">__verifyUrl__</a>
          </mj-text>
        </mj-column>
      </mj-section>

      <mj-section background-color="__brandSurface__" padding="0 32px 16px">
        <mj-column>
          <mj-text font-size="13px" color="__brandMuted__" padding="0">
            如非本人操作，请忽略此邮件，您的账户仍然安全。
          </mj-text>
        </mj-column>
      </mj-section>

      <mj-include path="../partials/footer.mjml" />
    </mj-wrapper>
  </mj-body>
</mjml>
