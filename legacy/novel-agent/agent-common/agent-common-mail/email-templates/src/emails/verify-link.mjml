<mjml lang="zh-CN">
  <mj-head>
    <mj-title>__productName__ 邮箱验证</mj-title>
    <mj-preview>请点击按钮完成邮箱验证，链接 __ttlLabel__ 内有效。</mj-preview>
    <mj-attributes>
      <mj-all font-family="'Courier New', Courier, 'Lucida Console', monospace" />
      <mj-text color="__brandText__" font-size="15px" line-height="24px" />
      <mj-button
        background-color="__brandPrimary__"
        color="#ffffff"
        font-size="14px"
        font-weight="700"
        border-radius="0"
        border="2px solid __brandBorder__"
        inner-padding="12px 28px"
        font-family="'Courier New', Courier, 'Lucida Console', monospace"
      />
    </mj-attributes>
    <mj-style inline="inline">
      .link-fallback { word-break: break-all; color: __brandPrimary__ !important; }
      .pixel-card { border: 2px solid __brandBorder__ !important; }
      @media only screen and (max-width: 480px) {
        .mobile-pad { padding-left: 12px !important; padding-right: 12px !important; }
      }
    </mj-style>
  </mj-head>
  <mj-body background-color="__brandBackground__" width="600px">
    <mj-wrapper padding="20px 12px" css-class="mobile-pad">
      <mj-include path="../partials/header.mjml" />

      <mj-section background-color="__brandSurface__" padding="16px 24px 0" border-left="2px solid __brandBorder__" border-right="2px solid __brandBorder__">
        <mj-column>
          <mj-text font-size="20px" font-weight="700" color="__brandText__" padding="0 0 8px" letter-spacing="0.04em">
            验证您的邮箱
          </mj-text>
          <mj-text color="__brandMuted__" padding="0 0 12px" font-size="14px">
            您正在 __productName__ 账户中验证邮箱。点击下方按钮即可完成验证；若按钮无法打开，请复制下方链接到浏览器。
          </mj-text>
        </mj-column>
      </mj-section>

      <mj-section background-color="__brandSurface__" padding="8px 24px 16px" border-left="2px solid __brandBorder__" border-right="2px solid __brandBorder__">
        <mj-column>
          <mj-button href="__verifyUrl__" align="left">
            验证邮箱
          </mj-button>
          <mj-text font-size="12px" color="__brandMuted__" padding="16px 0 0">
            链接 __ttlLabel__ 内有效
          </mj-text>
        </mj-column>
      </mj-section>

      <mj-section background-color="__brandSurface__" padding="0 24px 16px" border-left="2px solid __brandBorder__" border-right="2px solid __brandBorder__">
        <mj-column background-color="__brandSurface__" border="2px solid __brandBorder__" css-class="pixel-card">
          <mj-text font-size="12px" color="__brandMuted__" padding="14px" css-class="link-fallback">
            备用链接：<br />
            <a href="__verifyUrl__" style="color:__brandPrimary__;font-weight:700;">__verifyUrl__</a>
          </mj-text>
        </mj-column>
      </mj-section>

      <mj-section background-color="__brandSurface__" padding="0 24px 12px" border-left="2px solid __brandBorder__" border-right="2px solid __brandBorder__">
        <mj-column>
          <mj-text font-size="12px" color="__brandMuted__" padding="0">
            如非本人操作，请忽略此邮件，您的账户仍然安全。
          </mj-text>
        </mj-column>
      </mj-section>

      <mj-include path="../partials/footer.mjml" />
    </mj-wrapper>
  </mj-body>
</mjml>
